{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win-x64",
      "inherits": "base",
      "toolchainFile": "toolchains/win-x64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "win-x64"
      }
    },
    {
      "name": "win-arm64",
      "inherits": "base",
      "toolchainFile": "toolchains/win-arm64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "win-arm64"
      }
    },
    {
      "name": "linux-x64",
      "inherits": "base",
      "toolchainFile": "toolchains/linux-x64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "linux-x64"
      }
    },
    {
      "name": "linux-arm64",
      "inherits": "base",
      "toolchainFile": "toolchains/linux-arm64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "linux-arm64"
      }
    },
    {
      "name": "osx-x64",
      "inherits": "base",
      "toolchainFile": "toolchains/osx-x64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "osx-x64"
      }
    },
    {
      "name": "osx-arm64",
      "inherits": "base",
      "toolchainFile": "toolchains/osx-arm64.cmake",
      "cacheVariables": {
        "PIXELENGINE_TARGET_RID": "osx-arm64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win-x64",
      "configurePreset": "win-x64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    },
    {
      "name": "win-arm64",
      "configurePreset": "win-arm64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    },
    {
      "name": "linux-x64",
      "configurePreset": "linux-x64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    },
    {
      "name": "linux-arm64",
      "configurePreset": "linux-arm64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    },
    {
      "name": "osx-x64",
      "configurePreset": "osx-x64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    },
    {
      "name": "osx-arm64",
      "configurePreset": "osx-arm64",
      "targets": [
        "box2d_shared",
        "box2d_static"
      ]
    }
  ]
}
