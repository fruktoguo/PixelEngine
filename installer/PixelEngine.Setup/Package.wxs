<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="PixelEngine"
           Manufacturer="PixelEngine"
           Version="$(var.ProductVersion)"
           UpgradeCode="{6FCA8784-80DC-4E02-B8F4-93B5677C1E87}"
           Language="1033"
           InstallerVersion="500"
           Scope="perUser"
           Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of PixelEngine is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="PixelEngineIcon" SourceFile="$(var.ProductIcon)" />
    <Property Id="ARPPRODUCTICON" Value="PixelEngineIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/fruktoguo/PixelEngine" />
    <Property Id="INSTALLFOLDER" Secure="yes">
      <RegistrySearch Id="InstalledFolderSearch"
                      Root="HKCU"
                      Key="Software\PixelEngine"
                      Name="InstallFolder"
                      Type="raw" />
    </Property>
    <SetProperty Id="ARPINSTALLLOCATION" Value="[INSTALLFOLDER]" After="CostFinalize" Sequence="execute" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="LocalProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="PixelEngine" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PixelEngine" />
    </StandardDirectory>

    <Feature Id="Complete" Title="PixelEngine" Level="1">
      <ComponentGroupRef Id="EditorPayload" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
  </Package>

  <Fragment>
    <StandardDirectory Id="DesktopFolder" />
    <Component Id="ApplicationShortcuts" Directory="INSTALLFOLDER" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Directory="ApplicationProgramsFolder"
                Name="PixelEngine"
                Description="PixelEngine 2D pixel game engine"
                Target="[INSTALLFOLDER]PixelEngine.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="PixelEngineIcon" />
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="PixelEngine"
                Description="PixelEngine 2D pixel game engine"
                Target="[INSTALLFOLDER]PixelEngine.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="PixelEngineIcon" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      <RemoveFolder Id="RemoveLocalProgramsFolder" Directory="LocalProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\PixelEngine"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <RegistryValue Root="HKCU"
                     Key="Software\PixelEngine"
                     Name="InstallFolder"
                     Type="string"
                     Value="[INSTALLFOLDER]" />
      <RemoveRegistryKey Id="RemovePixelEngineRegistry"
                         Root="HKCU"
                         Key="Software\PixelEngine"
                         Action="removeOnUninstall" />
    </Component>
  </Fragment>
</Wix>
